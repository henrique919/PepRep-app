{
  "name": "expo-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "start:tunnel": "expo start --tunnel -c",
    "build:preview:android": "eas build --profile preview --platform android --non-interactive",
    "build:preview:ios": "eas build --profile preview --platform ios --non-interactive",
    "build:production:android": "eas build --profile production --platform android --non-interactive",
    "build:production:ios": "eas build --profile production --platform ios --non-interactive",
    "submit:production:android": "eas submit --profile production --platform android",
    "submit:production:ios": "eas submit --profile production --platform ios",
    "start-web": "expo start --web",
    "start-web-dev": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "export:web": "expo export --platform web",
    "deploy:web": "expo export --platform web && eas deploy"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/ibm-plex-mono": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/syne": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@nkzw/create-context-hook": "^1.1.0",
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^1.8.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-query": "^5.83.0",
    "@types/jest": "29.5.14",
    "@ungap/structured-clone": "^1.3.0",
    "date-fns": "^4.4.0",
    "expo": "~57.0.8",
    "expo-blur": "~57.0.2",
    "expo-constants": "~57.0.7",
    "expo-crypto": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-notifications": "~57.0.7",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.7",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.2",
    "jest": "~29.7.0",
    "lucide-react-native": "^0.475.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "ts-jest": "^29.4.11",
    "zod": "^4.1.12",
    "zustand": "^5.0.2"
