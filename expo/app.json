{
  "expo": {
    "name": "PepRep",
    "slug": "peprep-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "peprep",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F0E8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.henrique919.peprep"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#16161A"
      },
      "package": "com.henrique919.peprep"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d5833765-055d-4ee7-98e3-895ce3f66766"
      }
    },
    "owner": "henrique919"
  }
}
